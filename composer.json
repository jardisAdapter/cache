{
    "name": "jardisadapter/cache",
    "homepage": "https://docs.jardis.io/en/adapter/cache",
    "description": "PSR-16 multi-layer cache for PHP — stack Memory, APCu, Redis, and Database backends with automatic read-through backfill and write-through propagation; a building block of the open-source foundation that Jardis-generated DDD code runs on",
    "type": "library",
    "license": "MIT",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "authors": [
        {
            "name": "Jardis Development",
            "email": "jardisDev@headgent.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "psr/container": "^2.0",
        "psr/simple-cache": "^3.0",
        "ext-pdo": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^2.0.4",
        "squizlabs/php_codesniffer": "^3.11.2",
        "ext-json": "*",
        "ext-redis": "*",
        "ext-apcu": "*"
    },
    "suggest": {
        "ext-redis": "Required for CacheRedis adapter",
        "ext-apcu": "Required for CacheApcu adapter"
    },
    "autoload": {
        "psr-4": {
            "JardisAdapter\\Cache\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JardisAdapter\\Cache\\Tests\\": "tests/"
        }
    },    "support": {
        "issues": "https://github.com/jardisAdapter/cache/issues",
        "email": "jardisDev@headgent.com"
    },
    "keywords": [
        "cache",
        "database",
        "redis",
        "memory",
        "file",
        "domain-driven-design",
        "hexagonal-architecture",
        "psr-16",
        "multi-layer-cache",
        "php",
        "jardis"
    ]
}
