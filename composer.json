{
    "name": "jardisadapter/cache",
    "description": "PSR-16 multi-layer caching engine with write-through propagation across Redis, APCu, Database, and Memory",
    "type": "library",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "authors": [
        {
            "name": "Jardis Development",
            "email": "jardisDev@headgent.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "psr/container": "^2.0",
        "psr/simple-cache": "^3.0",
        "ext-pdo": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^2.0.4",
        "squizlabs/php_codesniffer": "^3.11.2",
        "ext-redis": "*",
        "ext-apcu": "*"
    },
    "suggest": {
        "ext-redis": "Required for CacheRedis adapter",
        "ext-apcu": "Required for CacheApcu adapter"
    },
    "autoload": {
        "psr-4": {
            "JardisAdapter\\Cache\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JardisAdapter\\Cache\\Tests\\": "tests/"
        }
    },
    "homepage": "https://github.com/jardisAdapter/cache",
    "support": {
        "issues": "https://github.com/jardisAdapter/cache/issues",
        "email": "jardisDev@headgent.com"
    },
    "keywords": [
        "cache",
        "database",
        "redis",
        "memory",
        "file",
        "domain driven design",
        "Jardis",
        "Headgent"
    ]
}
